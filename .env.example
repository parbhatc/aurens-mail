NODE_ENV=development
HTTP_HOST=127.0.0.1
HTTP_PORT=3100
SMTP_HOST=127.0.0.1
SMTP_PORT=2525
OUTBOUND_ENABLED=false
# scripts/configure-postfix-outbound.sh replaces this with the current
# aurens-mail Docker network gateway before the app container is recreated.
OUTBOUND_SMTP_HOST=172.18.0.1
OUTBOUND_SMTP_PORT=2587
OUTBOUND_SMTP_SECURE=false
OUTBOUND_SMTP_REQUIRE_TLS=false
# OUTBOUND_SMTP_USER=
# OUTBOUND_SMTP_PASSWORD=
DATABASE_URL=postgres://aurens_mail:change-me@127.0.0.1:5432/aurens_mail
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=aurens-mail
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me
EMAIL_DOMAIN=aurens.app
APP_ORIGIN=http://localhost:5173
COOKIE_SECURE=false
MAX_EMAIL_SIZE=26214400
MAX_ATTACHMENT_SIZE=15728640
MAX_ATTACHMENTS=50
TRASH_RETENTION_DAYS=30
SPAM_RETENTION_DAYS=30
OWNER_EMAIL=admin@aurens.app
OWNER_PASSWORD=replace-with-a-long-random-password
LOG_LEVEL=info

# Optional deployment metadata used by local deployment tooling.
# Keep credentials and private-key contents out of this file.
DEPLOY_HOST=your-vps-ip
DEPLOY_PORT=22
DEPLOY_USER=root
DEPLOY_PATH=/opt/aurens-mail
